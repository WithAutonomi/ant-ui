{
  "identifier": "default",
  "description": "Default capabilities for ant-gui",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "process:default",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
