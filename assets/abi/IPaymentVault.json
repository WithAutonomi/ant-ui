[
  {
    "type": "function",
    "name": "payForQuotes",
    "inputs": [
      {
        "name": "_payments",
        "type": "tuple[]",
        "components": [
          { "name": "rewardsAddress", "type": "address" },
          { "name": "amount", "type": "uint256" },
          { "name": "quoteHash", "type": "bytes32" }
        ]
      }
    ],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "payForMerkleTree",
    "inputs": [
      { "name": "depth", "type": "uint8" },
