    "name": "MerklePaymentMade",
    "inputs": [
      { "name": "winnerPoolHash", "type": "bytes32", "indexed": true },
      { "name": "depth", "type": "uint8", "indexed": false },
      { "name": "totalAmount", "type": "uint256", "indexed": false },
      { "name": "merklePaymentTimestamp", "type": "uint64", "indexed": false }
    ]
  }
